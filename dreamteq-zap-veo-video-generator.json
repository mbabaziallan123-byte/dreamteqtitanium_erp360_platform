            "payload_type": "json",
            "data": "{\"url\":\"{{300__catalog_url}}\",\"formats\":[\"markdown\",\"links\",\"screenshot\"],\"actions\":[{\"type\":\"scroll\",\"direction\":\"down\",\"amount\":2000}],\"waitFor\":3000,\"includeTags\":[\"img\",\"h1\",\"h2\",\"h3\",\"p\",\"a\"],\"removeBase64Images\":false}"
