            "payload_type": "json",
            "data": "{\"contents\":[{\"parts\":[{\"text\":\"You are a product catalog parser. Extract product listings from this scraped eCommerce catalog page.\\n\\nSCRAPED CONTENT:\\n{{301__data__markdown}}\\n\\nADDITIONAL PAGE LINKS:\\n{{301__data__links}}\\n\\nExtract up to {{300__product_limit}} products and return a JSON array ONLY (no explanation):\\n[\\n  {\\n    \\\"product_index\\\": 1,\\n    \\\"title\\\": \\\"product name\\\",\\n    \\\"image_url\\\": \\\"full absolute https URL to main product image\\\",\\n    \\\"product_url\\\": \\\"link to product detail page\\\",\\n    \\\"price\\\": \\\"price string or empty\\\",\\n    \\\"description\\\": \\\"1 sentence max\\\",\\n    \\\"category\\\": \\\"clothing type (dress, shirt, pants, etc.)\\\",\\n    \\\"colors\\\": \\\"color(s) mentioned\\\"\\n  }\\n]\\n\\nOnly include products with valid image URLs. Prioritize fashion/apparel items. Return ONLY the JSON array.\"}]}]}"
          },
          "meta": {
            "$editor": { "has_automatic_issues": false },
            "parammap": {},
            "stepTitle": "Step 3: Gemini AI — Parse & Extract Product List"
