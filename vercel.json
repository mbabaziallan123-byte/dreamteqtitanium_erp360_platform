{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": null,
  "framework": null,
  "functions": {
    "api/sync.js": {
      "maxDuration": 30
    },
    "api/security-fetch.js": {
      "maxDuration": 15
    },
    "api/whatsapp-webhook.js": {
      "maxDuration": 10
    },
    "api/mpesa-callback.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/sync",
      "dest": "/api/sync.js"
    },
    {
      "src": "/api/security-fetch",
      "dest": "/api/security-fetch.js"
    },
    {
      "src": "/api/whatsapp-webhook",
      "dest": "/api/whatsapp-webhook.js"
    },
    {
      "src": "/api/mpesa-callback",
      "dest": "/api/mpesa-callback.js"
    },
    {
      "src": "/100APPS.HTML",
      "dest": "/100APPS.HTML"
    },
    {
      "src": "/LMSENTREPRISE.HTML",
      "dest": "/LMSENTREPRISE.HTML"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-API-Key" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; frame-src 'self' https:;" }
      ]
    }
  ]
}
