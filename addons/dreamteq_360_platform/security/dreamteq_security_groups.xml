<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_dreamteq_titanium_erp" model="ir.module.category">
            <field name="name">DreamTeQ Titanium ERP Access Controls</field>
            <field name="description">Administrative categorization handling smallholder identity layers and ledger permissions.</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_dreamteq_smallholder_user" model="res.groups">
            <field name="name">Ecosystem Smallholder User</field>
            <field name="category_id" ref="dreamteq_360_platform.module_category_dreamteq_titanium_erp"/>
            <field name="comment">Restricted access profile matching standalone local mini-app transactions endpoints.</field>
        </record>

        <record id="group_dreamteq_cto_master_overseer" model="res.groups">
            <field name="name">CTO Master Overseer (Gods Mode)</field>
            <field name="category_id" ref="dreamteq_360_platform.module_category_dreamteq_titanium_erp"/>
            <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
            <field name="comment">Unrestricted administration access mapping across active container layers and ledger data tables.</field>
        </record>

        <record id="rule_dreamteq_smallholder_dynamic_ledger_isolation" model="ir.rule">
            <field name="name">Smallholder Dynamic Ledger Record Isolation</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="domain_force">[('partner_id.ref', '=', 'PHONE-' + user.login)]</field>
            <field name="groups" eval="[(4, ref('dreamteq_360_platform.group_dreamteq_smallholder_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
