# DreamTeQ_360 Firecrawl Scraper Module — Local Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git (.gitignore must include .env*)
# Mirror all secrets in the Vercel vault: Settings → Environment Variables
# -----------------------------------------------------------------

# ── Firecrawl v2 Live Web Intelligence ────────────────────────────
FIRECRAWL_API_KEY=fc-202e15708a0444299021412bfcc48298

# ── Google Gemini Pro (cognitive reasoning agent) ─────────────────
GEMINI_API_KEY=FILL_IN_your_gemini_api_key

# ── PostgreSQL (DreamTeQ ERP master database) ────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://dreamteq_operator:FILL_IN_password@db:5432/dreamteq_master_pool

# ── Redis cache (default resolves via Docker DNS inside mesh) ─────
REDIS_URL=redis://redis-cache:6379/0

# ── IoT MQTT Telematics Broker ───────────────────────────────────
# Hostname ONLY — no protocol prefix
MQTT_BROKER_HOST=broker.hivemq.com
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=dreamteq/farm

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
