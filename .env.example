# DreamTeQ_360 Titanium ERP — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git (.gitignore already covers it).
#
# Product of Dreamteam Consulting Company, Box 3515-00100, Nairobi, Kenya
# -----------------------------------------------------------------

# ── PostgreSQL (dreamteq-db & odoo18-core) ────────────────────────
POSTGRES_USER=dreamteq_operator
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=dreamteq_master_pool

# ── Supabase (api/sync.js, api/security-fetch.js) ─────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_JWT
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_JWT
DREAMTEQ_API_SECRET=CHANGE_ME_api_secret_here

# ── Supabase pg_dump backup (supabase_production_backup.js) ───────
SUPABASE_PRODUCTION_DB_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── WhatsApp Business API (whatsapp_notifier.js) ──────────────────
WHATSAPP_PHONE_NUMBER_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=YOUR_META_WHATSAPP_ACCESS_TOKEN

# ── WhatsApp Inbound Webhook (api/whatsapp-webhook.js) ────────────
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_webhook_verify_token

# ── WhatsApp AI Gateway (whatsapp_ai_router.js) ───────────────────
WHATSAPP_AI_GATEWAY_TOKEN=CHANGE_ME_gateway_bearer_token
WHATSAPP_ADMIN_PHONE=254XXXXXXXXX
WA_AI_ROUTER_PORT=8095
# Monica AI invitation context — set via Vercel vault and local .env
MONICA_INVITATION_CODE=CHANGE_ME_monica_invitation_code
# Operator audit email — used in server console log only, never in HTTP responses
ADMIN_CONTACT_EMAIL=CHANGE_ME_operator_email

# ── Email Alert Notifier (pipeline_exception_notifier.js) ─────────
DREAMTEQ_MAIL_HOST=smtp.gmx.com
DREAMTEQ_MAIL_PORT=465
DREAMTEQ_MAIL_USER=dreamteamconsult@gmx.com
DREAMTEQ_MAIL_PASSWORD=CHANGE_ME_mail_password
DREAMTEQ_NOTIFY_LIST=cto@dreamteamconsult.site,dreamteamconsult@gmx.com
# Set to 1 to skip actual sending during local testing
DREAMTEQ_MAIL_DRY_RUN=0

# ── Redis (local override — default resolves via Docker DNS) ───────
REDIS_HOST=dreamteq-cache
REDIS_PORT=6379

# ── WebSocket broker ──────────────────────────────────────────────
WS_PORT=8085

# ── Vercel Connectivity Probe (test_vercel_push.js) ───────────────
VERCEL_HOST=project-jx0pu.vercel.app

# ── Firecrawl Live Web Intelligence (firecrawl_skills.js) ─────────
# Obtain your key at https://firecrawl.dev/ — store in Vercel vault & local .env only
FIRECRAWL_API_KEY=CHANGE_ME_firecrawl_api_key

# ── Google Gemini Pro (dreamteq_scraper_module/agents.py) ─────────
# Obtain at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME_gemini_api_key

# ── Report Compiler (test_report_compilation.js) ──────────────────
REPORT_COMPILER_HOST=localhost
REPORT_COMPILER_PORT=8090
